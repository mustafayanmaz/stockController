    {
      "name": "09 - Create Order #1 (FIFO beklenen totalCost=6000)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"productCode\": \"{{productCode}}\",\n  \"quantity\": 60,\n  \"unitPrice\": 200.00\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/orders",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "orders"
          ]
        },
        "description": "Kalan lotlar remove sonrasi 70@100 + 50@120 oldugu icin ilk 60 tamamen 100 maliyetli lottan tuketilir."
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "const json = pm.response.json();",
              "pm.collectionVariables.set('order1Id', String(json.orderId));",
              "pm.collectionVariables.set('order1Code', json.orderCode);",
              "",
              "pm.test('Order response alanlari dolu', function () {",
              "    pm.expect(json.orderId).to.be.a('number');",
              "    pm.expect(json.orderCode).to.be.a('string');",
              "    pm.expect(json.productCode).to.eql(pm.collectionVariables.get('productCode'));",
              "});",
              "",
              "pm.test('FIFO cost kontrolu #1', function () {",
              "    pm.expect(Number(json.totalCost)).to.eql(6000);",
              "    pm.expect(Number(json.totalAmount)).to.eql(12000);",
              "    pm.expect(Number(json.grossProfit)).to.eql(6000);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
